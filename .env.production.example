# ============================================================
# BACKEND (Spring Boot) production environment — Supabase DB
# Copy to `.env` for docker-compose, or set these on your host.
# ============================================================

# --- Supabase PostgreSQL ---
# Dashboard -> Project Settings -> Database -> Connection string.
# Use the SESSION POOLER (port 5432) — it supports prepared statements &
# Flyway migrations and gives an IPv4 address. Add ?sslmode=require.
#   Host:     aws-0-<region>.pooler.supabase.com
#   Database: postgres
#   User:     postgres.<your-project-ref>
DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.<your-project-ref>
DB_PASSWORD=your-supabase-db-password
DB_POOL_SIZE=5
DB_POOL_MIN=1

# --- JWT signing secret (long random). Generate: openssl rand -base64 48 ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# --- Gmail SMTP (App Password, spaces removed) ---
MAIL_USERNAME=nextgenlabs.edu@gmail.com
MAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM=NextGen Labs <nextgenlabs.edu@gmail.com>
EMAIL_COMPANY_INBOX=nextgenlabs.edu@gmail.com

# --- CORS: your deployed frontend origin(s), comma-separated, NO trailing slash ---
CORS_ORIGINS=https://www.nextgenlabs.ai,https://nextgenlabs.ai

# --- Seed super admin (first boot only; 14+ chars, meets policy) ---
SUPER_ADMIN_EMAIL=admin@nextgenlabs.ai
SUPER_ADMIN_PASSWORD=Choose-A-Strong-14plus-Char-Password!

# --- Optional Cloudflare Turnstile ---
TURNSTILE_ENABLED=false
TURNSTILE_SECRET=

# ============================================================
# FRONTEND (Vite) — set at BUILD time on your static host
# ============================================================
# VITE_API_URL=https://api.nextgenlabs.ai
# VITE_TURNSTILE_SITE_KEY=
